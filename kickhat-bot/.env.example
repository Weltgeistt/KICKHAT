# --- Veritabani ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kickhat

# --- API guvenligi (website ve masaustu uygulamasiyla ayni olmali) ---
API_KEY=degistir-beni

# --- AI moderasyon ---
OPENAI_API_KEY=

# --- Chat'e mesaj gonderme: Yol 1 (RESMI, onerilen) ---
# dev.kick.com uzerinden app olustur, chat:write scope'u ver
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
# Bot olarak konusacak Kick hesabinin kullanici adi.
# Bu hesapla kickhat.net/login -> "Kick ile Bagla" yapilmali (token DB'ye duser).
BOT_KICK_USERNAME=

# --- Chat'e mesaj gonderme: Yol 2 (GAYRIRESMI, yedek) ---
# Kick hesabinin oturum token'i (kirilgan, sadece resmi yol yoksa)
KICK_SESSION_TOKEN=

# --- Site adresi (!stats komutunun verdigi link) ---
SITE_URL=https://kickhat.net
