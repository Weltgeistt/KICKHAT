{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KICKHAT",
  "version": "1.0.0",
  "identifier": "com.aftek.kickhat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KICKHAT",
        "width": 420,
        "height": 780,
        "minWidth": 340,
        "minHeight": 500,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:11434 https://kick.com https://*.kick.com wss://ws-us2.pusher.com https://sockjs-us2.pusher.com; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://kickhat.com/public/downloads/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4MTVGRTIzOTU1Qjk5ODAKUldTQW1WdVZJLzRWR0V0MUdGdklrR3NoSWdkZ000OXhEeURNaWFDYUhHaWVUbExBUWhHV2NDUlYK"
    }
  }
}
