# Bot API baglantisi (website sunucu tarafi icin — istemciye SIZMAZ)
BOT_API_URL=http://127.0.0.1:3000
# Sunucudaki API_KEY env degeriyle ayni olmali
BOT_API_KEY=kickhat-secret-key-123

# Oturum cerezi imza anahtari (rastgele uzun bir deger uret)
SESSION_SECRET=cok-gizli-rastgele-deger

# Admin yetkisi verilecek Kick kullanici adlari (virgullu)
ADMIN_USERS=poyland,ademiru
